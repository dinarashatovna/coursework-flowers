@if (Visible)
{
    <div class="modal-backdrop" @onclick="OnBackdropClick">
        <div class="modal" role="dialog" aria-modal="true" @onclick:stopPropagation="true">
            <h3 class="modal__title">@Title</h3>
            <p class="modal__body">@Message</p>
            <div class="modal__actions">
                <button class="btn btn--ghost" type="button" @onclick="OnCancel">@CancelText</button>
                <button class="btn btn--primary" type="button" @onclick="OnConfirm">@ConfirmText</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Title { get; set; } = "Подтверждение";
    [Parameter] public string Message { get; set; } = "Вы уверены?";
    [Parameter] public string ConfirmText { get; set; } = "Да";
    [Parameter] public string CancelText { get; set; } = "Отмена";
    [Parameter] public EventCallback OnConfirmed { get; set; }
    [Parameter] public EventCallback OnCancelled { get; set; }

    private async Task OnConfirm() => await OnConfirmed.InvokeAsync();
    private async Task OnCancel() => await OnCancelled.InvokeAsync();
    private async Task OnBackdropClick() => await OnCancelled.InvokeAsync();
}
